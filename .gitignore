# Game runtime saves (Config.td5 / CupData.td5 — XOR-encrypted, regenerated at
# runtime by td5_save.c; never source). Accidentally committed once from a
# recovery-scratch dir on 2026-05-29.
*.td5

# Original game files (copyrighted — do not distribute)
original/

# Extracted / derived game assets (copyrighted data)
re/assets/
re/unused_assets/
re/td5_dump/
re/td5_png/
re/td5_png_clean/

# Throwaway /fix + /end visual-verification captures (swept by /end Step 6)
re/screenshots/

# Large RE tools / cloned repos (not project source)
pyghidra_projects/
/tools/*
/tools/*/
/frida_pool/
/traces/

