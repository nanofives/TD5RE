# Game runtime saves (Config.td5 / CupData.td5 — XOR-encrypted, regenerated at
# runtime by td5_save.c; never source). Accidentally committed once from a
# recovery-scratch dir on 2026-05-29.
*.td5

# Organized INI runtime saves written by td5_save.c (input/progress/cup config;
# regenerated at runtime, never source — same rationale as *.td5 above). Anchored
# to repo root so the TRACKED td5re.ini / td5re_release.ini are unaffected.
/td5re_input.ini
/td5re_progress.ini
/td5re_cup.ini

# Dev/QA pending-test checklist (written by td5_pending.c, pruned by /end). Local
# runtime state, seeded from the compiled-in default list — never source.
/td5re_pending.txt

# Original game files (copyrighted — do not distribute)
original/

# Extracted / derived game assets (copyrighted data)
re/assets/
re/unused_assets/
re/td5_dump/
re/td5_png/
re/td5_png_clean/

# Throwaway /fix + /end visual-verification captures (swept by /end Step 6)
re/screenshots/

# Large RE tools / cloned repos (not project source)
pyghidra_projects/
/tools/*
/tools/*/
/frida_pool/
/traces/

# Exceptions: divergence sweep + race-diff tooling is tracked. Keep this list
# in sync with `git ls-files tools/` — a tracked file missing here would be
# silently dropped by any rm --cached / re-add cycle.
!/tools/diff_replay_frames.py
!/tools/td5_actor_offsets.py
!/tools/run_state_replay.py
!/tools/frida_chassis_probe.js
!/tools/frida_cascade_probe.js
!/tools/frida_traffic_compare.js
!/tools/diff_traffic_compare.py
!/tools/diff_profiles.py
!/tools/diff_race.py
!/tools/frida_ai_probe.js
!/tools/frida_pool14_00434350.js
!/tools/frida_pool5_00405D70.js
!/tools/frida_race_trace.js
!/tools/run_ai_probe.py

