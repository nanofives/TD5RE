# Active /fix worktrees (per-session scratch, not project state)
.claude/worktrees/

# Per-session test scratch written at a worktree root by the /fix launch harness.
# .claude/worktrees/ above does NOT cover these when git is run from INSIDE the
# worktree (its own root is the repo root there), so list them explicitly.
.td5re_test_pid
manual_drive.exe

# Per-session scratch dropped at the .claude/ root (screen/particle tags, session
# env, client copies, worktree backup patches) and the repo root — not project
# state. Tracked .claude content (commands/*.md) is unaffected by these globs.
.claude/.*_tag
.claude/.mt_session_env
.claude/td5re_client_copy
.claude/worktree_*.patch
*_manual_pid

# Local release-packaging artifact (regenerated by the release-zip recipe)
/TD5RE.zip

# verify/ runtime output (snap.ps1 is the tool; PNGs/logs are stale per-run)
verify/td5re_*.png
verify/td5re_*.log
verify/*.log

# Ghidra project clones inside research-archive (DB state, not research)
re/tools/research-archive/tmp_ghidra_proj/

# Root-folder cleanup archive (regenerable scratch parked for review before deletion)
_archive/

# Retired binary .DAT assets moved here by the pack-on-load retirement
# (local backup; originals also live in original/ ZIPs — not for version control)
re/_retired_dats/

# Test Drive 6 source install (326 MB; copyrighted upstream game data, not VC)
Test Drive 6/

# Generated release manifest (regenerated by scripts/make_release_manifest.ps1 on every publish)
/manifest.json

# Car Studio vendors three.js here on first run (downloaded, not version-controlled)
re/tools/car_studio/vendor/
*.manual_drive_pid
